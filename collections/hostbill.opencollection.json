              {
                "name": "call",
                "value": "",
                "type": "query"
              }
            ]
          },
          "docs": "List invoices"
        }
      ]
    },
    {
      "info": {
        "name": "Orders",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "List orders",
            "type": "http"
          },
          "http": {
            "method": "POST",
